pipeline{
    agent any
    stages {
        stage("CheckOut SCM"){
            steps {
                checkout scm
            }
        }
        stage("Docker Login"){
            steps {
                withCredientials([usernamePassword(
                    credientialsId: '',
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_PASS'
                )])
                sh ''' echo "$DOCKER_PASS" | docker login -u "$DOCKER_USER" --password-stdin '''
            }
        }
    }
}